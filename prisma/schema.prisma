generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EDITOR
}

enum CollectionName {
  TILES
  SANITARYWARE
  DOORS
}

model CollectionMeta {
  id          String         @id @default(cuid())
  collection  CollectionName @unique
  title       String
  tagline     String?
  videoUrl    String?
  updatedAt   DateTime       @updatedAt
}

model User {
  id        String   @id @default(uuid()) // Maps to Supabase Auth User ID
  email     String   @unique
  firstName String?
  lastName  String?
  role      Role     @default(EDITOR)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      ActivityLog[]
}

model Category {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  icon        String?       // Supabase Storage URL
  collection  CollectionName @default(TILES)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  subcategories Subcategory[]
  products    Product[]
}

model Subcategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Brand {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  logo        String?   // Supabase Storage URL
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  sku              String         @unique
  description      String         @db.Text
  features         String[]
  specifications   Json?          // Flexible JSON for varying specs (Material, Finish, Color, Dimensions)
  
  categoryId       String
  category         Category       @relation(fields: [categoryId], references: [id])
  subcategoryId    String?
  subcategory      Subcategory?   @relation(fields: [subcategoryId], references: [id])
  
  isAvailable      Boolean        @default(true)
  isFeatured       Boolean        @default(false)
  
  // SEO
  metaTitle        String?
  metaDescription  String?
  metaKeywords     String?
  
  images           ProductImage[]
  
  isDeleted        Boolean        @default(false) // Soft delete
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model ProductImage {
  id         String   @id @default(cuid())
  url        String   // Supabase Storage URL
  publicId   String   // Storage Path for deletion
  altText    String?
  isPrimary  Boolean  @default(false)
  order      Int      @default(0)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Inquiry {
  id               String   @id @default(cuid())
  name             String
  mobileNumber     String
  email            String?
  message          String   @db.Text
  productReference String?  // SKU or Product URL
  status           String   @default("NEW") // NEW, IN_PROGRESS, RESOLVED, ARCHIVED
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model GalleryAlbum {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  coverImage  String?
  media       GalleryMedia[]
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model GalleryMedia {
  id           String       @id @default(cuid())
  url          String
  publicId     String
  type         String       // IMAGE or VIDEO
  albumId      String
  album        GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  order        Int          @default(0)
  createdAt    DateTime     @default(now())
}

model HomepageContent {
  id          String   @id @default(cuid())
  section     String   @unique // HERO, ABOUT, FEATURES
  content     Json     // Structured content
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model ContactInformation {
  id           String   @id @default(cuid())
  address      String   @db.Text
  mapUrl       String?  @db.Text
  phones       String[]
  whatsapp     String
  email        String
  hours        String
  catalogueUrl String?
  socialLinks  Json?
  updatedAt    DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  entity    String   // e.g., PRODUCT, CATEGORY
  entityId  String?
  details   Json?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
